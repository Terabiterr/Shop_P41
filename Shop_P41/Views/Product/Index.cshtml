@model IEnumerable<Product>

@{
    ViewData["Title"] = "Product List";
    Layout = "_Layout";
}

<table class="table table-info">
        <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th>Description</th>
            <th>Quantity</th>
            <th>Category</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>@product.Description</td>
                <td>@product.Quantity</td>
                <td>@product.CategoryId</td>
            </tr>
        }
    </tbody>
</table>